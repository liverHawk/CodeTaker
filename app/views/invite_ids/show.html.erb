<div class="mx-auto w-full max-w-2xl px-4 py-10">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight text-gray-900">Invite ID</h1>
    <p class="mt-1 text-sm text-gray-600">
      Your invite ID can be revealed only once. After that, it will be marked as used.
    </p>
  </div>

  <% if @error %>
    <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <%= @error %>
    </div>
  <% end %>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <% if !@confirmed %>
      <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        You need to confirm your account before revealing an invite ID.
      </div>
    <% elsif @invite_id %>
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="text-sm font-medium text-gray-700">Your invite ID</div>
          <div class="mt-2 font-mono text-2xl font-semibold tracking-widest text-gray-900" id="invite-id">
            <%= @invite_id %>
          </div>
        </div>

        <button
          type="button"
          class="inline-flex items-center justify-center rounded-md bg-gray-900 px-3 py-2 text-sm font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2"
          data-invite-copy
        >
          Copy
        </button>
      </div>

      <p class="mt-4 text-sm text-gray-600">
        Click Pricing and Upgrade. On the right side, you will see a button to "promo code". Click it and paste your invite ID.
      </p>

      <script>
        (() => {
          const button = document.querySelector("[data-invite-copy]");
          const text = document.getElementById("invite-id")?.textContent?.trim();
          if (!button || !text) return;
          button.addEventListener("click", async () => {
            try {
              await navigator.clipboard.writeText(text);
              const prev = button.textContent;
              button.textContent = "Copied";
              setTimeout(() => (button.textContent = prev), 1200);
            } catch (_) {
              // no-op
            }
          });
        })();
      </script>
    <% elsif @already_assigned %>
      <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        You have already redeemed your invite id.
      </div>
    <% else %>
      <div class="text-sm text-gray-700">
        You don't have an invite id yet.
      </div>
      <div class="mt-4">
        <%= button_to "Reveal invite id (one-time)",
                      invite_ids_path,
                      method: :post,
                      data: { turbo: false },
                      class: "inline-flex items-center justify-center rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2" %>
      </div>
    <% end %>
  </div>
</div>