<div class="mx-auto w-full max-w-2xl px-4 py-10">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight text-gray-900">URLの追加</h1>
    <p class="mt-1 text-sm text-gray-600">http/https のURLのみ登録できます。</p>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <% if @user.errors.any? %>
      <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
        <div class="font-medium">入力内容を確認してください</div>
        <ul class="mt-2 list-disc pl-5">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: profile_url_path, method: :patch do |f| %>
      <div>
        <%= f.label :url, "URL", class: "block text-sm font-medium text-gray-700" %>
        <%= f.url_field :url,
                        placeholder: "https://example.com",
                        class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900",
                        autocomplete: "url" %>
        <p class="mt-2 text-xs text-gray-500">
          空にすると未設定に戻せます。
        </p>
      </div>

      <div class="mt-6 flex items-center justify-between">
        <%= link_to "戻る",
                    root_path,
                    class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
        <%= f.submit "更新する",
                     class: "inline-flex items-center justify-center rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2" %>
      </div>
    <% end %>
  </div>
</div>

